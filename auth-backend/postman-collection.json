{
  "info": {
    "name": "Auth Backend API",
    "description": "Express + SQLite Authentication API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/auth" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Register User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/register" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  var jsonData = pm.response.json();",
              "  pm.collectionVariables.set('token', jsonData.token);",
              "  pm.test('Registration successful', function() {",
              "    pm.expect(jsonData.message).to.contain('successfully');",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Register - Duplicate User (Error)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/register" }
      }
    },
    {
      "name": "3. Register - Invalid Email (Error)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"invalid-email\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/register" }
      }
    },
    {
      "name": "4. Register - Short Password (Error)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test2@example.com\",\n  \"password\": \"123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/register" }
      }
    },
    {
      "name": "5. Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/login" }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var jsonData = pm.response.json();",
              "  pm.collectionVariables.set('token', jsonData.token);",
              "  pm.test('Login successful', function() {",
              "    pm.expect(jsonData.token).to.be.a('string');",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Login - Wrong Password (Error)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"wrongpassword\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/login" }
      }
    },
    {
      "name": "7. Get Profile (Protected)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/profile" }
      }
    },
    {
      "name": "8. Get Profile - No Token (Error)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/profile" }
      }
    },
    {
      "name": "9. Get All Users (Testing)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/users" }
      }
    }
  ]
}
