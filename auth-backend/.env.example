PORT=3000
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=1h

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=TravelMate <your_email@gmail.com>
FRONTEND_URL=http://localhost:8080

# Supabase (server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Amadeus
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Package tuning
PACKAGE_ORIGIN_IATA=JFK
PACKAGE_MAX_PRICE_USD=2500
PACKAGE_FETCH_LIMIT=40
PACKAGE_CACHE_TTL_MINUTES=720
PACKAGE_BUDGET_THRESHOLD_USD=700
PACKAGE_HONEYMOON_THRESHOLD_USD=1400
PACKAGE_DOMESTIC_COUNTRY_CODE=US
PACKAGE_COLD_REFRESH_ON_ITEM_MISS=true
PACKAGE_REFRESH_INTERVAL_MINUTES=360
PACKAGE_RATE_LIMIT_WINDOW_MS=60000
PACKAGE_RATE_LIMIT_MAX_REQUESTS=80
